# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=backend_template_db
DB_ECHO=false
DB_POOL_SIZE=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true
DB_ECHO_POOL=false

# Auth configuration
AUTH_SECRET_KEY=your-super-secret-key-minimum-32-characters-long-for-production
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

# Application configuration
ENVIRONMENT=development
APP_PORT=8000
